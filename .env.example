# ----- Backend -----
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_HOST=db
# Host-facing Postgres port (mapped to the container's internal 5432).
# Using 5434 avoids clashing with a local Postgres on the default 5432.
DATABASE_PORT=5434
DATABASE_USER=review
DATABASE_PASSWORD=review
DATABASE_NAME=review_queue
# Auto-create schema from entities on boot. Convenient for the assignment;
# switch to migrations for production (see README roadmap).
DB_SYNCHRONIZE=true

# Auth
JWT_SECRET=super-secret-change-me
JWT_EXPIRES_IN=8h

# Reservation / queue behavior

# Per the brief, the hold is 20 minutes. Lower it (e.g. 1) to make the
# auto-release flow quick to test or to record the walkthrough video.
RESERVATION_TTL_MINUTES=1
# How often the background reaper scans for expired reservations (ms)
REAPER_INTERVAL_MS=15000

# In-memory cache TTL for hot read paths (ms)
CACHE_TTL_MS=3000

# Per-reviewer rate limiting for reserve attempts
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Ingestion
# Re-seed from tickets/ JSON files only when the tickets table is empty
SEED_ON_BOOT=true
# Optional continuous ticket generator to simulate live ingestion
GENERATE_TICKETS=false
GENERATE_INTERVAL_MS=30000

# ----- UI (build-time) -----
# Base path the browser uses to reach the API (proxied by nginx in Docker)
VITE_API_BASE=/api
